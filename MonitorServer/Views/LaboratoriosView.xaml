<UserControl x:Class="MonitorServer.Views.LaboratoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorServer.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#001F3F">
            <TextBlock Text="Tec Lab Manager - Servidor"
                       Foreground="White"
                       FontSize="17"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="16,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="14,12,14,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
            Content="Descubrir Equipos (UDP Broadcast)"
            Height="34"
            Cursor="Hand"
            Padding="12,0"
            Background="#0072C6"
            Foreground="White"
            FontSize="13"
            FontWeight="SemiBold"
            Command="{Binding DescubrirComputadorasCommand}"/>

            <Button Grid.Column="2"
            Content="Ver Historial"
            Cursor="Hand"
            Height="34"
            Padding="16,0"
            FontSize="13"
            FontWeight="Normal"
            Command="{Binding VerHistorialCommand}"/>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Laboratorios"
                   FontSize="15"
                   FontWeight="Bold"
                   Margin="16,8,0,6"
                   Foreground="#222222"/>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      Margin="14,0,14,8">
            <StackPanel>

                <TextBlock Text="Ningun equipo descubierto. Presiona Descubrir o espera a que los clientes se conecten."
                           FontSize="13"
                           Foreground="#999999"
                           Margin="0,0,0,0"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Laboratorios.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Laboratorios}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,4"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Stretch"
                                    Background="#F5F7FA"
                                    BorderBrush="#DDDDDD"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.SeleccionarLaboratorioCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding .}">
                                <Grid>
                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Foreground="#1A1A1A"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="CANTIDAD: "
                                                   FontSize="13"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="{Binding Cantidad}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#0056D2"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="4" Background="#001F3F">
            <TextBlock Foreground="White" FontSize="12" VerticalAlignment="Center" Padding="10,0,0,0">
                <Run Text="Total de laboratorios: "/>
                <Run Text="{Binding Laboratorios.Count, Mode=OneWay}"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
