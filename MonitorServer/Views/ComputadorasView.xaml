<UserControl x:Class="MonitorServer.Views.ComputadorasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorServer.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#001F3F">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="Computadoras de "
                           Foreground="White"
                           FontSize="17"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LaboratorioSeleccionado}"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#F5F7FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Regresar" Cursor="Hand"
                        Width="110" Height="30"
                        Margin="0,0,10,0"
                        FontSize="13"
                        Command="{Binding RegresarLaboratoriosCommand}"/>
                <Button Content="Actualizar todas" Cursor="Hand"
                        Width="130" Height="30"
                        Background="#0072C6"
                        Foreground="White"
                        FontSize="13"
                        Command="{Binding ComprobarEstadoTodasCommand}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Computadoras}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD"
                                    BorderThickness="0,0,0,1"
                                    Background="#FFEAFAF1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="82"/>
                                        <ColumnDefinition Width="82"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Nombre}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Internet: "
                                                   FontSize="13"
                                                   Foreground="#555555"/>
                                        <TextBlock
                                                   FontSize="13"
                                                   FontWeight="SemiBold" >
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Sin conexión" />
                                                    <Setter Property="Foreground" Value="#D20056"></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TieneInternet}" Value="True">
                                                            <Setter Property="Text" Value="Con Conexión" />
                                                            <Setter Property="Foreground" Value="#00D27C"></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Estado: "
                                                   FontSize="13"
                                                   Foreground="#555555"/>
                                        <TextBlock
                                                   FontSize="13"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Apagada" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Encendida}" Value="True">
                                                            <Setter Property="Text" Value="Encendida" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBlock Text="IP: "
                                            FontSize="13"
                                        Foreground="#555555"/>
                                        <TextBlock
                                        FontSize="13" Text="{Binding IP}"
                                    FontWeight="SemiBold">
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="4"
                                            Content="Apagar"
                                            Cursor="Hand"
                                            Height="26"
                                            Margin="0,0,6,0"
                                            FontSize="12"
                                            Background="#CC0000"
                                            Foreground="White"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ApagarComputadoraCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Grid.Column="5"
                                            Content="Actualizar"
                                            Cursor="Hand"
                                            Height="26"
                                            FontSize="12"
                                            Background="#0078D7"
                                            Foreground="White"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ComprobarEstadoCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#001F3F">
            <TextBlock Foreground="White" FontSize="12" VerticalAlignment="Center" Padding="10,0,0,0">
                <Run Text="Total de computadoras: "/>
                <Run Text="{Binding Computadoras.Count, Mode=OneWay}"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
