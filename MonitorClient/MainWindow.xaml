<Window x:Class="MonitorClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MonitorClient"
        xmlns:viewmodel="clr-namespace:MonitorClient.ViewModels"
        xmlns:views="clr-namespace:MonitorClient.Views"
        mc:Ignorable="d"
        Title="Cliente Monitor" Height="450" Width="800">
    <Window.DataContext>
        <viewmodel:ClienteViewModel></viewmodel:ClienteViewModel>
    </Window.DataContext>
    <Window.Resources>
        <views:ClienteView x:Key="ClienteView"></views:ClienteView>
        <views:ApagarComputadoraView x:Key="ApagarComputadoraView"></views:ApagarComputadoraView>
    </Window.Resources>
    <ContentControl>
        <ContentControl.Style>
            <Style TargetType="ContentControl">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Vista}" Value="{x:Static viewmodel:Vistas.Cliente}">
                        <Setter Property="Content" Value="{StaticResource ClienteView}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Vista}" Value="{x:Static viewmodel:Vistas.ApagarComputadora}">
                        <Setter Property="Content" Value="{StaticResource ApagarComputadoraView}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ContentControl.Style>
    </ContentControl>
</Window>
