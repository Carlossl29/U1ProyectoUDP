<UserControl x:Class="MonitorClient.Views.ClienteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorClient.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#001F3F" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="&#xE713;"
                       FontFamily="Segoe MDL2 Assets"
                       Foreground="White" FontSize="20"
                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Configuracion del Cliente Tec Lab"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="30,20">
            <!--<TextBlock Text="Dirección IP del servidor:" Margin="0,0,0,10"
                   FontSize="16" Foreground="#333" FontWeight="SemiBold"/>
        <TextBox Height="35" FontSize="16" VerticalContentAlignment="Center"
                 Text="{Binding DireccionIP}"/>-->
            <TextBlock Text="Identificador del Equipo:" Margin="0,15,0,10" 
                   FontSize="16" Foreground="#333" FontWeight="SemiBold"/>
            <TextBox Height="35" FontSize="16" VerticalContentAlignment="Center"
                 Text="{Binding Identificador}" IsEnabled="{Binding ConectarBoton}"/>
            <Button Content="Guardar y conectarse al servidor" Background="#0072C6" Height="45" FontSize="16" Cursor="Hand" Margin="0,20"
                IsEnabled="{Binding ConectarBoton}" Command="{Binding ConectarCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter Property="Background" Value="#0072C6"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="G"></Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="Background" Value="Gainsboro"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Background="#001F3F">
            <TextBlock Text="{Binding Mensaje}"
                   Foreground="White" FontSize="13"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
